<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Error <%= status %> — FarmaTrack</title>
  <link rel="stylesheet" href="/css/farmatrack.css" />
  <style>
    body { display:flex; align-items:center; justify-content:center; min-height:100vh; margin:0; background:#f5f6fa; font-family:sans-serif; }
    .error-box { text-align:center; padding:3rem 4rem; background:#fff; border-radius:12px; box-shadow:0 4px 24px rgba(0,0,0,.08); }
    .error-box__code { font-size:6rem; font-weight:800; color:#e53e3e; line-height:1; margin:0; }
    .error-box__msg  { font-size:1.2rem; color:#4a5568; margin:1rem 0 2rem; }
    .btn-back { display:inline-block; padding:.75rem 2rem; background:#2d6a4f; color:#fff; border-radius:8px; text-decoration:none; font-weight:600; }
  </style>
</head>
<body>
  <div class="error-box">
    <p class="error-box__code"><%= status || 500 %></p>
    <p class="error-box__msg"><%= message || 'Algo salió mal.' %></p>
    <a href="/" class="btn-back">← Volver al inicio</a>
  </div>
</body>
</html>
